{
  "name": "continuim",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Policy-enforced autonomous procurement for stockout emergencies.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "setup": "sh scripts/bootstrap.sh && npm install",
    "bootstrap": "npm run setup",
    "dev": "concurrently -n control,procurement,web -c cyan,yellow,green \"npm run dev:control\" \"npm run dev:procurement\" \"npm run dev:web\"",
    "dev:control": "node --env-file-if-exists=.env --watch --import tsx services/control-plane/src/server.ts",
    "dev:procurement": "node --env-file-if-exists=.env --watch --import tsx services/procurement/src/server.ts",
    "dev:web": "node --env-file-if-exists=.env node_modules/next/dist/bin/next dev apps/dashboard --hostname 127.0.0.1 --port 3000",
    "dev:evidence": "node --env-file-if-exists=.env --watch --import tsx scripts/evidence-adapter.ts",
    "test": "node --import tsx --test packages/security/src/capability.test.ts services/verification/src/policy.test.ts services/verification/src/scenarios.test.ts services/agent/src/loop.test.ts services/agent/src/learning.test.ts services/procurement/src/authorize.test.ts services/procurement/src/index.test.ts services/control-plane/src/monitor.test.ts services/control-plane/src/store.test.ts services/zero-adapter/src/adapter.test.ts services/procurement/src/email.test.ts services/zero-adapter/src/transport.test.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test",
    "build:web": "node --env-file-if-exists=.env node_modules/next/dist/bin/next build apps/dashboard",
    "build": "npm run check && npm run build:web",
    "start:control": "node --env-file-if-exists=.env --import tsx services/control-plane/src/server.ts",
    "start:procurement": "node --env-file-if-exists=.env --import tsx services/procurement/src/server.ts",
    "start:web": "node --env-file-if-exists=.env node_modules/next/dist/bin/next start apps/dashboard --hostname 0.0.0.0 --port 3000",
    "start:evidence": "node --env-file-if-exists=.env --import tsx scripts/evidence-adapter.ts",
    "demo": "node --env-file-if-exists=.env --import tsx scripts/demo.ts",
    "doctor": "node --env-file-if-exists=.env --import tsx scripts/doctor.ts",
    "doctor:prize": "CONTINUIM_REQUIRE_PRIZE=1 node --env-file-if-exists=.env --import tsx scripts/doctor.ts"
  },
  "engines": {
    "node": ">=22.10"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.5.19",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
