# Local mode is safe, deterministic, and visibly labeled in the dashboard.
CONTROL_PLANE_HOST=127.0.0.1
CONTROL_PLANE_PORT=4000
PROCUREMENT_HOST=127.0.0.1
PROCUREMENT_PORT=4001
CONTROL_PLANE_INTERNAL_URL=http://127.0.0.1:4000
PROCUREMENT_URL=http://127.0.0.1:4001
AUTH_MODE=development
VERIFICATION_MODE=fixture
ATTESTATION_SIGNING_SECRET=local-attestation-only-change-me
DEMO_STEP_DELAY_MS=350
SQLITE_PATH=data/stockshield.db
MONITOR_ENABLED=1
MONITOR_INTERVAL_MS=2000
MONITOR_REQUESTED_QTY=20

# Nexla posts the frozen StockoutRiskEvent contract to /api/events/stockout.
# NEXLA_WEBHOOK_SECRET=

# Live Zero mode uses a small owner-supplied adapter that normalizes paid results.
# Every paid signal must include a real receiptId or the control plane rejects it.
# VERIFICATION_MODE=live_zero
# ZERO_EVIDENCE_ADAPTER_URL=http://127.0.0.1:4100/v1/evidence
# ZERO_EVIDENCE_ADAPTER_TOKEN=
# ZERO_EVIDENCE_TIMEOUT_MS=45000

# Prize mode: the agent reaches procurement only through this Pomerium route.
# AUTH_MODE=pomerium
# POMERIUM_ROUTE_URL=https://po.<starter-domain>
# POMERIUM_JWKS_URL=https://po.<starter-domain>/.well-known/pomerium/jwks.json
# POMERIUM_ISSUER=po.<starter-domain>
# POMERIUM_AUDIENCE=po.<starter-domain>
# POMERIUM_SUBJECT_PREFIX=vendor:
# POMERIUM_AGENT_TOKEN=<authenticated-agent-token-denied-by-vendor-policy>
# POMERIUM_VENDOR_TOKEN_VENDOR_NORTHSTAR=<vendor-scoped-service-account-token>

# Active demo scenario profile: datacenter (default) or apparel
SCENARIO=datacenter
