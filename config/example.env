# Safe local defaults. Copy to .env.local; never commit the resulting file.
CONTROL_PLANE_PORT=4000
PROCUREMENT_PORT=4001
NEXT_PUBLIC_CONTROL_PLANE_URL=http://127.0.0.1:4000
PROCUREMENT_URL=http://127.0.0.1:4001
AUTH_MODE=development
DEV_CAPABILITY_SECRET=local-development-only-change-me
ATTESTATION_SIGNING_SECRET=local-attestation-only-change-me
DEMO_STEP_DELAY_MS=350

# Prize-demo mode: set AUTH_MODE=pomerium and populate all values below.
# POMERIUM_ROUTE_URL=https://po.<your-starter-domain>
# POMERIUM_JWKS_URL=https://po.<your-starter-domain>/.well-known/pomerium/jwks.json
# POMERIUM_ISSUER=po.<your-starter-domain>
# POMERIUM_AUDIENCE=po.<your-starter-domain>
# POMERIUM_VENDOR_TOKEN_VENDOR_NORTHSTAR=<service-account-token>

# Owner 2 fills these only after one successful paid call per pinned service.
# ZERO_VERIFICATION_MODE=live
# ZERO_COMPANY_SERVICE_ID=
# ZERO_WEB_SERVICE_ID=
# ZERO_NEWS_SERVICE_ID=
# ZERO_EMAIL_SERVICE_ID=
