# Local mode is safe, deterministic, and visibly labeled in the dashboard.
CONTROL_PLANE_HOST=127.0.0.1
CONTROL_PLANE_PORT=4000
PROCUREMENT_HOST=127.0.0.1
PROCUREMENT_PORT=4001
CONTROL_PLANE_INTERNAL_URL=http://127.0.0.1:4000
PROCUREMENT_URL=http://127.0.0.1:4001
VERIFICATION_MODE=fixture
ATTESTATION_SIGNING_SECRET=local-attestation-only-change-me
DEMO_STEP_DELAY_MS=350
SQLITE_PATH=data/continuim.db
MONITOR_ENABLED=1
MONITOR_INTERVAL_MS=2000
MONITOR_REQUESTED_QTY=20

# External systems can post the frozen StockoutRiskEvent contract (source
# "webhook") to /api/events/stockout. Unset means the endpoint accepts
# unauthenticated events — set a secret anywhere the port is reachable.
# STOCKOUT_WEBHOOK_SECRET=

# Live mode gathers real public evidence in-process (services/verification/src/live.ts):
# rdap.org for domain registration (free, keyless), Firecrawl for the vendor site
# scrape (key required), Linkup for optional news mentions. Provider failures omit
# signals and the policy fails closed (decision 0010) — nothing is ever fabricated.
# VERIFICATION_MODE=live
# Firecrawl example: fc-...
# FIRECRAWL_API_KEY=
# LINKUP_API_KEY=
# PROVIDER_TIMEOUT_MS=12000
# EVIDENCE_CACHE_TTL_MS=600000

# Optional low-cost/free explainer via OpenRouter. The policy still decides.
# Create an OpenRouter API key, then set OPENROUTER_API_KEY in your local .env.
# OPENROUTER_EXPLAINER_ENABLED=1
# OPENROUTER_API_KEY=
# Gemma 4 26B A4B IT is currently free on OpenRouter.
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# OPENROUTER_TIMEOUT_MS=20000
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_APP_NAME=Continuim

# Optional local fallback explainer: authenticate Claude Code with
# `claude setup-token` and set CLAUDE_CODE_OAUTH_TOKEN, or use an existing local
# Claude Code login. This is only a non-authoritative explainer fallback.
# CLAUDE_EXPLAINER_ENABLED=0
# CLAUDE_MODEL=sonnet
# CLAUDE_MAX_BUDGET_USD=0.02
# CLAUDE_TIMEOUT_MS=20000

# Active demo scenario profile: datacenter (default) or apparel
SCENARIO=datacenter
