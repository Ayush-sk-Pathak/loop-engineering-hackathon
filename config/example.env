# Local mode is safe, deterministic, and visibly labeled in the dashboard.
CONTROL_PLANE_HOST=127.0.0.1
CONTROL_PLANE_PORT=4000
PROCUREMENT_HOST=127.0.0.1
PROCUREMENT_PORT=4001
CONTROL_PLANE_INTERNAL_URL=http://127.0.0.1:4000
PROCUREMENT_URL=http://127.0.0.1:4001
AUTH_MODE=development
VERIFICATION_MODE=fixture
ATTESTATION_SIGNING_SECRET=local-attestation-only-change-me
DEMO_STEP_DELAY_MS=350
SQLITE_PATH=data/continuim.db
MONITOR_ENABLED=1
MONITOR_INTERVAL_MS=2000
MONITOR_REQUESTED_QTY=20

# Nexla posts the frozen StockoutRiskEvent contract to /api/events/stockout.
# NEXLA_WEBHOOK_SECRET=
# NEXLA_API_KEY=

# Live mode gathers real public evidence in-process (services/verification/src/live.ts):
# rdap.org for domain registration (free, keyless), Firecrawl for the vendor site
# scrape (key required), Linkup for optional news mentions. Provider failures omit
# signals and the policy fails closed (decision 0010) — nothing is ever fabricated.
# VERIFICATION_MODE=live
# Firecrawl example: fc-...
# FIRECRAWL_API_KEY=
# LINKUP_API_KEY=
# PROVIDER_TIMEOUT_MS=12000
# EVIDENCE_CACHE_TTL_MS=600000

# Optional low-cost/free explainer via OpenRouter. The policy still decides.
# Create an OpenRouter API key, then set OPENROUTER_API_KEY in your local .env.
# OPENROUTER_EXPLAINER_ENABLED=1
# OPENROUTER_API_KEY=
# Gemma 4 26B A4B IT is currently free on OpenRouter.
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# OPENROUTER_TIMEOUT_MS=20000
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_APP_NAME=Continuim

# Amazon Bedrock is an explainer/planner surface only. The policy still decides.
# BEDROCK_EXPLAINER_ENABLED=1
# AWS_BEARER_TOKEN_BEDROCK=
# The available key is region-bound to ap-south-1. Use Amazon Nova through the
# APAC inference profile so Bedrock works without Anthropic model-access approval.
# BEDROCK_REGION=ap-south-1
# BEDROCK_MODEL_ID=apac.amazon.nova-micro-v1:0
# BEDROCK_TIMEOUT_MS=20000

# Optional local fallback when Bedrock is blocked: authenticate Claude Code with
# `claude setup-token` and set CLAUDE_CODE_OAUTH_TOKEN, or use an existing local
# Claude Code login. This is only a non-authoritative explainer fallback.
# CLAUDE_EXPLAINER_ENABLED=0
# CLAUDE_MODEL=sonnet
# CLAUDE_MAX_BUDGET_USD=0.02
# CLAUDE_TIMEOUT_MS=20000

# Optional local fallback when Bedrock and Claude API access are blocked: authenticate
# the Codex CLI with `codex login`. This is only a non-authoritative explainer fallback.
# CODEX_EXPLAINER_ENABLED=0
# CODEX_MODEL=gpt-5.6-luna
# CODEX_TIMEOUT_MS=30000

# Prize mode: the agent reaches procurement only through this Pomerium route.
# AUTH_MODE=pomerium
# POMERIUM_ROUTE_URL=https://po.<starter-domain>
# POMERIUM_JWKS_URL=https://po.<starter-domain>/.well-known/pomerium/jwks.json
# POMERIUM_ISSUER=po.<starter-domain>
# POMERIUM_AUDIENCE=po.<starter-domain>
# POMERIUM_SUBJECT_PREFIX=vendor:
# Optional comma-separated vendor ID to Pomerium subject aliases, for hosted accounts
# whose service-account subject differs from Continuim's canonical vendor:<id> form.
# POMERIUM_VENDOR_SUBJECT_ALIASES=vendor-northstar=sfhack
# POMERIUM_AGENT_TOKEN=<authenticated-agent-token-denied-by-vendor-policy>
# POMERIUM_VENDOR_TOKEN_VENDOR_NORTHSTAR=<token>
# POMERIUM_ZERO_TOKEN=

# Akash is deploy-time hosting coverage, not an app runtime key.
# AKASH_API_KEY=
# AKASH_WALLET_ADDRESS=
# AKASH_KEY_NAME=
# AKASH_NET=https://raw.githubusercontent.com/akash-network/net/main/mainnet
# AKASH_PROVIDER_HOST=provider.cpu.aesservices.net
# AKASH_INGRESS_URI=

# Active demo scenario profile: datacenter (default) or apparel
SCENARIO=datacenter
