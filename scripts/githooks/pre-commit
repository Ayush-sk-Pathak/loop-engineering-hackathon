#!/bin/sh
set -eu

staged="$(git diff --cached --name-only)"

if printf '%s\n' "$staged" | grep -Eq '(^|/)\.env($|\.(local|development|production|test)$)'; then
  echo "pre-commit: refusing a staged runtime environment file" >&2
  exit 1
fi

# Scan ADDED lines only: deletions cannot introduce a new secret, and matching them
# false-positives on removed placeholders (see errors.jsonl 2026-07-17 hook-false-positive).
if git diff --cached | grep '^+' | grep -Eiq '(BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY|POMERIUM_VENDOR_TOKEN_[A-Z_]+=.{12}|ANTHROPIC_API_KEY=sk[-])'; then
  echo "pre-commit: possible credential detected in staged content" >&2
  exit 1
fi

if [ -d node_modules ]; then
  npm run check
else
  echo "pre-commit: node_modules missing; run npm run setup before committing" >&2
  exit 1
fi
